{
  "expo": {
    "name": "RopeGeo",
    "slug": "RopeGeo",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "ropegeo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0f64b6b2-d71d-4161-bc58-9002596085ce"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yurst3.RopeGeo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["comgooglemaps", "maps"],
        "CADisableMinimumFrameDurationOnPhone": true,
        "UIBackgroundModes": ["processing"],
        "BGTaskSchedulerPermittedIdentifiers": [
          "com.expo.modules.backgroundtask.processing"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF6B00",
        "foregroundImage": "./assets/images/androidLogo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.yurst3.RopeGeo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splashLogoLight.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FF6B00",
          "dark": {
            "image": "./assets/images/splashLogoDark.png",
            "backgroundColor": "#FF6B00"
          }
        }
      ],
      [
        "@rnmapbox/maps"
      ],
      "./plugins/withMapboxNativeMarkerImages",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "RopeGeo uses your location while you use the app to show where you are on the map, center the explore view on your position, and sort search results by distance from you. For example, when you browse routes on the map, your location helps you see nearby canyoneering areas and how far you are from them."
        }
      ],
      "expo-background-task",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Roboto_400Regular.ttf",
            "./assets/fonts/Roboto_700Bold.ttf",
            "./assets/fonts/Merriweather_400Regular.ttf",
            "./assets/fonts/Merriweather_700Bold.ttf",
            "./assets/fonts/ComicNeue_400Regular.ttf",
            "./assets/fonts/ComicNeue_700Bold.ttf",
            "./assets/fonts/DancingScript_400Regular.ttf",
            "./assets/fonts/DancingScript_700Bold.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0f64b6b2-d71d-4161-bc58-9002596085ce"
      }
    }
  }
}
